{
  "name": "@khoralabs/observability",
  "version": "0.0.0",
  "description": "Shared Bun server observability: Pino logger, OpenTelemetry SDK init, span helpers, env utilities.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./logger": {
      "types": "./src/logger.ts",
      "import": "./src/logger.ts",
      "default": "./src/logger.ts"
    },
    "./otel": {
      "types": "./src/otel.ts",
      "import": "./src/otel.ts",
      "default": "./src/otel.ts"
    },
    "./otel-env": {
      "types": "./src/otel-env.ts",
      "import": "./src/otel-env.ts",
      "default": "./src/otel-env.ts"
    },
    "./spans": {
      "types": "./src/spans.ts",
      "import": "./src/spans.ts",
      "default": "./src/spans.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.203.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.203.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.203.0",
    "@opentelemetry/instrumentation-pino": "^0.50.0",
    "@opentelemetry/resources": "^2.0.1",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.203.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "pino": "^9.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "pino-pretty": "^13.0.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
